# AquaCam stream config
# Times use 24h format HH:MM (server local time)

# YouTube ingest
STREAM_URL="rtmp://a.rtmp.youtube.com/live2"
STREAM_KEY_FILE="/home/<PI_USER>/aquacam-stream/stream.key"

# Capture/encode
VIDEO_DEVICE="/dev/video0"
INPUT_FORMAT="mjpeg"
FRAMERATE="30"
VIDEO_SIZE="640x480"
VIDEO_BITRATE="1200k"
MAXRATE="1200k"
BUFSIZE="2400k"
GOP="60"
AUDIO_BITRATE="128k"
AUDIO_RATE="44100"

# Retry behavior
MAX_RETRIES="0"          # 0 = infinite retries
RETRY_DELAY="10"         # seconds

# Daily schedule (empty disables check)
START_TIME="08:30"       # do not stream before this time
STOP_TIME="20:30"        # stop stream at/after this time
CHECK_INTERVAL="20"      # seconds between schedule checks
STUCK_TIMEOUT_SECONDS="480"  # local-only stuck detection threshold

# Power management after stop window
SHUTDOWN_AFTER_STOP="true"
SHUTDOWN_TIME="20:35"
SHUTDOWN_DELAY_SECONDS="300"

# Logging
LOG_FILE="/home/<PI_USER>/aquacam-stream/stream.log"
PROGRESS_FILE="/tmp/aquacam-ffmpeg.progress"
# One-time warm restart shortly after service boot to clear YouTube preparing stalls
WARM_RESTART_ENABLED="true"
WARM_RESTART_AFTER_SECONDS="120"
